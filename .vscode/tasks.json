{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "web: lint",
      "type": "shell",
      "command": "npm run lint",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "group": "test",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "web: build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "group": "build"
    },
    {
      "label": "api: test",
      "type": "shell",
      "command": "go test ./...",
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "group": "test"
    },
    {
      "label": "api: vet",
      "type": "shell",
      "command": "go vet ./...",
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "group": "test"
    }
  ]
}

{
  "makefile.configureOnOpen": false,

  "eslint.workingDirectories": ["apps/web"],
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],

  "tailwindCSS.experimental.configFile": "apps/web/tailwind.config.ts",

  "typescript.tsdk": "apps/web/node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/out": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.next/**": true
  },

  "[go]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "golang.go",
    "editor.tabSize": 4,
    "editor.insertSpaces": false
  },
  "[go.mod]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "golang.go"
  },
  "[typescript]": {
    "editor.tabSize": 2
  },
  "[typescriptreact]": {
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.tabSize": 2
  },

  "gopls": {
    "ui.semanticTokens": true,
    "build.directoryFilters": ["-apps/web", "-deployments", "-docs", "-.git"]
  }
}

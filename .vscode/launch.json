{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: run main",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/apps/api/cmd/api",
      "cwd": "${workspaceFolder}/apps/api",
      "env": {},
      "args": []
    },
    {
      "name": "Web: Next.js dev (terminal)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
